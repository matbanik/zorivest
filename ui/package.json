{
    "name": "zorivest-ui",
    "version": "0.1.0",
    "private": true,
    "description": "Zorivest trading portfolio manager — Electron desktop application",
    "main": "./out/main/index.js",
    "scripts": {
        "dev": "concurrently -k -n ui,api -c cyan,yellow \"npm:dev:ui\" \"npm:dev:api\"",
        "dev:ui": "cross-env ZORIVEST_BACKEND_URL=http://127.0.0.1:17787 electron-vite dev",
        "dev:api": "cd ../packages/api && cross-env ZORIVEST_DEV_UNLOCK=1 ZORIVEST_APPROVAL_CALLBACK_PORT=17788 uv run uvicorn zorivest_api.main:app --host 127.0.0.1 --port 17787 --reload",
        "dev:ui-only": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "lint": "eslint src/ --max-warnings 0",
        "typecheck": "tsc --noEmit",
        "test": "vitest run --reporter=verbose",
        "test:watch": "vitest",
        "test:smoke": "npx tsx scripts/smoke-test.ts"
    },
    "dependencies": {
        "@codemirror/lang-json": "^6.0.2",
        "@codemirror/state": "^6.6.0",
        "@codemirror/theme-one-dark": "^6.1.3",
        "@codemirror/view": "^6.41.0",
        "@hookform/resolvers": "^3.0.0",
        "@radix-ui/react-dialog": "^1.0.0",
        "@radix-ui/react-dropdown-menu": "^2.0.0",
        "@radix-ui/react-popover": "^1.0.0",
        "@radix-ui/react-scroll-area": "^1.0.0",
        "@radix-ui/react-select": "^2.0.0",
        "@radix-ui/react-slot": "^1.0.0",
        "@radix-ui/react-tabs": "^1.0.0",
        "@radix-ui/react-tooltip": "^1.0.0",
        "@tanstack/react-query": "^5.90.0",
        "@tanstack/react-router": "^1.166.0",
        "@tanstack/react-table": "^8.21.0",
        "@tanstack/react-virtual": "^3.5.0",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.1.0",
        "codemirror": "^6.0.2",
        "cronstrue": "^3.14.0",
        "electron-store": "^8.2.0",
        "fuse.js": "^7.0.0",
        "lucide-react": "^0.400.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-hook-form": "^7.54.0",
        "sonner": "^1.7.0",
        "tailwind-merge": "^2.5.0",
        "zod": "^3.24.0",
        "zustand": "^5.0.0"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.1",
        "@eslint/js": "^9.39.4",
        "@playwright/test": "^1.58.2",
        "@tailwindcss/vite": "^4.2.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.6.0",
        "@testing-library/react": "^16.1.0",
        "@testing-library/user-event": "^14.5.0",
        "@types/node": "^22.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.3.0",
        "babel-plugin-react-compiler": "^1.0.0",
        "concurrently": "^9.2.1",
        "cross-env": "^7.0.3",
        "electron": "^41.0.0",
        "electron-builder": "^26.8.0",
        "electron-vite": "^5.0.0",
        "eslint": "^9.0.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "jsdom": "^25.0.0",
        "prettier": "^3.4.0",
        "tailwindcss": "^4.2.0",
        "typescript": "^5.8.0",
        "typescript-eslint": "^8.57.0",
        "vitest": "^3.0.0"
    }
}
